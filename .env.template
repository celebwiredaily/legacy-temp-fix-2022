# GitHub Actions Video Automation - Environment Variables Template
# Copy this to .env and fill in your values
# DO NOT commit .env to git!

# ====================================
# GITHUB CONFIGURATION (For ActivePieces integration)
# ====================================

# Your GitHub username or organization name
GITHUB_REPO_OWNER=your-username

# Your repository name (e.g., "video-automation-actions")
GITHUB_REPO_NAME=video-automation-actions

# GitHub Personal Access Token (with 'repo' scope)
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ====================================
# VIDEO SOURCE APIs (OPTIONAL)
# ====================================

# Pexels API (optional - only needed if not using Pinterest)
# Get free key from: https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay API (optional - only needed if not using Pinterest)
# Get free key from: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Note: If you're using Pinterest scraper exclusively, 
# you can leave the above API keys empty!


# ====================================
# CLOUD STORAGE (OPTIONAL)
# ====================================

# AWS S3 (optional - for automatic video uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Google Drive (optional - requires rclone setup)
# See: https://rclone.org/drive/
RCLONE_CONFIG=

# Dropbox (optional)
DROPBOX_ACCESS_TOKEN=


# ====================================
# NOTIFICATIONS (OPTIONAL)
# ====================================

# Email notifications (optional)
MAIL_USERNAME=
MAIL_PASSWORD=
NOTIFICATION_EMAIL=

# Slack webhook (optional)
SLACK_WEBHOOK_URL=


# ====================================
# GITHUB SECRETS TO CONFIGURE
# ====================================
# 
# Go to your repository → Settings → Secrets and variables → Actions
# Add these secrets (copy values from above):
#
# For API sources (if not using Pinterest):
# - PEXELS_API_KEY
# - PIXABAY_API_KEY
#
# For cloud storage (if using):
# - AWS_ACCESS_KEY_ID
# - AWS_SECRET_ACCESS_KEY
# - S3_BUCKET
# - RCLONE_CONFIG
# - DROPBOX_ACCESS_TOKEN
#
# For notifications (if using):
# - MAIL_USERNAME
# - MAIL_PASSWORD
# - SLACK_WEBHOOK
#
# Note: GITHUB_TOKEN is auto-generated, no need to add it manually!
#
# ====================================


# ====================================
# TESTING LOCALLY (OPTIONAL)
# ====================================

# If you want to test the ActivePieces trigger script locally:
# python activepieces_github_trigger.py

# These variables are used for local testing only:
# (Same as GITHUB_* variables above)
